# =============================================================================
# GEMFILE - Ruby Dependencies
# =============================================================================
# This file tells GitHub Pages which Jekyll version and plugins to use.
# You don't need to install anything locally - GitHub handles this automatically.

source "https://rubygems.org"

# Use the github-pages gem for full compatibility
gem "github-pages", group: :jekyll_plugins

# Plugins that work with GitHub Pages
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end
